# ============================================================
# .env.example — Ukraine Combat Footage Web Application
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Database ──────────────────────────────────────────────
# Async SQLAlchemy URL (used by FastAPI backend + ml-engine)
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/ukraine_footage
# Sync SQLAlchemy URL (used by Celery tasks which cannot use async)
DATABASE_SYNC_URL=postgresql://postgres:yourpassword@localhost:5432/ukraine_footage

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Kaggle API ────────────────────────────────────────────
# Download from kaggle.com → Account → API → "Create New API Token"
# Place kaggle.json at %USERPROFILE%\.kaggle\kaggle.json (Windows)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Authentication (Admin Panel) ─────────────────────────
# JWT secret must be at least 32 characters
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8
# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# ── Media Storage ─────────────────────────────────────────
MEDIA_ROOT=./media
RAW_VIDEO_DIR=./media/raw
ANNOTATED_VIDEO_DIR=./media/annotated
DATASETS_DIR=./media/datasets
MODELS_DIR=./media/models

# ── ML Configuration ─────────────────────────────────────
GPU_DEVICE=cuda:0
YOLO_BASE_MODEL=yolov8m.pt
YOLO_BATCH_SIZE=8
YOLO_EPOCHS_BASELINE=100
YOLO_EPOCHS_FINETUNE=50
GROUNDING_DINO_CONFIG=./ml-engine/core/autolabeling/GroundingDINO_SwinT_OGC.py
GROUNDING_DINO_CHECKPOINT=./ml-engine/core/autolabeling/groundingdino_swint_ogc.pth
GROUNDING_DINO_BOX_THRESHOLD=0.35
GROUNDING_DINO_TEXT_THRESHOLD=0.25
# Default text prompt for auto-labeling
GROUNDING_DINO_PROMPT=military vehicle, tank, armored vehicle, armored personnel carrier, soldier, armed personnel, drone, UAV, artillery, truck, helicopter

# ── Scraping Configuration ────────────────────────────────
FUNKER530_BASE_URL=https://funker530.com
SCRAPE_DELAY_SECONDS=2
SCRAPE_MAX_PAGES=10
YTDLP_FORMAT=bestvideo[ext=mp4][height<=1080]+bestaudio[ext=m4a]/best[ext=mp4]/best
# Comma-separated list of YouTube channel URLs or IDs to monitor
YOUTUBE_CHANNELS=

# ── Kaggle Datasets for Stage 1 Baseline Training ─────────
# Comma-separated list of Kaggle dataset slugs
KAGGLE_BASELINE_DATASETS=sudipchakrabarty/kiit-mita

# ── Web Application ───────────────────────────────────────
DEBUG=true
SECRET_KEY=change-me-fastapi-secret-key
# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_PREFIX=/api
FEED_PAGE_SIZE=20

# ── GCP (Phase 4 Only) ───────────────────────────────────
GCS_BUCKET=ukraine-footage-media
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./infra/gcp/service-account-key.json
