{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(mkdir:*)",
      "Bash(celery:*)",
      "Bash(redis-cli:*)",
      "Bash(playwright:*)",
      "Bash(yt-dlp:*)",
      "Bash(psql:*)",
      "Bash(alembic:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(docker:*)",
      "Bash(gcloud:*)"
    ]
  },
  "env": {
    "PYTHONPATH": ".",
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "notes": {
    "docker": "Docker is Phase 4 only — do not use docker commands during local development",
    "gcloud": "GCP commands are Phase 4 only",
    "gpu": "GPU tasks use concurrency=1 on dedicated 'gpu' Celery queue to protect 8GB VRAM"
  }
}
